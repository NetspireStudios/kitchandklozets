# Normalize line endings so Windows/Mac/Linux contributors don't fight git.
* text=auto eol=lf

# Treat all text source as LF on disk regardless of OS.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.rules text eol=lf

# Binary assets should never have CRLF substitution.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
