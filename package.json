{
  "name": "kitchandklozets",
  "version": "1.0.0",
  "private": true,
  "description": "Custom cabinetmaker brochure site for Kitch & Klozets, Watertown MA. Static HTML + JSX shared components; catalog HTML generated from data.",
  "homepage": "https://kitchandklozets.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/NetspireStudios/kitchandklozets.git"
  },
  "scripts": {
    "generate":   "node scripts/generate-catalog-pages.js",
    "preview":    "firebase emulators:start",
    "deploy":     "firebase deploy --only hosting,firestore",
    "deploy:all": "firebase deploy",
    "lint:check": "node -e \"['data.jsx','catalog-data.jsx','utils.jsx','top.jsx','middle.jsx','bottom.jsx','catalog.jsx'].forEach(f => require('node:fs').readFileSync(f,'utf8'))\""
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
